# =============================================================================
# Mealie Configuration
# =============================================================================

# The URL the MCP server uses to make API calls to Mealie.
# If the MCP server and Mealie are on the same Docker network, use the internal
# Docker DNS address — this is the recommended setup:
#   MEALIE_BASE_URL=http://mealie:9000
# If the MCP server cannot reach Mealie internally, use the external URL you
# use to access the Mealie web interface in your browser:
#   MEALIE_BASE_URL=https://your-mealie-instance.com
MEALIE_BASE_URL=http://mealie:9000

# Your Mealie API key. Generate one inside Mealie under:
# Profile (top-right avatar) → API Tokens → Create
MEALIE_API_KEY=your-mealie-api-key

# How much detail to include in server logs.
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# INFO is recommended for normal use. DEBUG is very noisy but helpful when
# troubleshooting connection or authentication problems.
LOG_LEVEL=INFO

# =============================================================================
# OAuth / Authentik Configuration
# =============================================================================
#
# OVERVIEW (skip if you already know OAuth)
# -----------------------------------------
# OAuth is a login system that lets users authenticate through a central login
# server (Authentik) instead of handing their credentials directly to this
# server. Here is what happens when a user connects their MCP client:
#
#   1. The MCP client (Claude, ChatGPT, etc.) contacts this server.
#   2. This server says "go log in at Authentik first".
#   3. The user logs into Authentik in their browser.
#   4. Authentik issues a short-lived token and sends the user back.
#   5. The MCP client presents that token on every request.
#   6. This server checks the token's signature and expiry using Authentik's
#      public signing keys (JWKS). No password is ever sent to this server.
#
# Authentication is OPTIONAL. If AUTHENTIK_ISSUER is not set, the server
# starts without any authentication — useful for local testing.
# =============================================================================

# The issuer URL for the OAuth2 provider you created in Authentik.
# Found in Authentik admin under: Applications → Providers → (your provider)
#   → "OpenID Configuration Issuer" field.
# Format: https://<your-authentik-host>/application/o/<provider-slug>/
# This is used to fetch Authentik's public signing keys (to verify tokens) and
# to validate the issuer claim inside each token.
AUTHENTIK_ISSUER=https://auth.your-oauth-instance.com/application/o/mealie-mcp-server/

# The public URL of THIS MCP server — the address your MCP client uses to
# reach it. This is NOT your Mealie URL and NOT your Authentik URL.
# When a client connects and is challenged to log in, the server advertises
# this URL so the client knows where to find the OAuth metadata.
# No trailing slash. No /mcp path.
MCP_SERVER_URL=https://your-mcp-server.your-domain.com

# (Optional) The Client ID of your Authentik provider.
# Found in Authentik admin under: Applications → Providers → (your provider)
#   → "Client ID" field.
# If set, the server checks that incoming tokens were issued specifically for
# this server (not just any valid Authentik token). Most simple or personal
# setups can leave this unset.
# AUTHENTIK_AUDIENCE=

# (Optional) Fetch Authentik's signing keys from an internal Docker network
# address instead of going through the public internet. Skips OIDC discovery
# and hits Authentik directly — more efficient when both services share a
# Docker network.
# Format: http://<internal-docker-hostname>:9000/application/o/<provider-slug>/jwks/
# Leave unset to use automatic discovery via AUTHENTIK_ISSUER.
AUTHENTIK_JWKS_URI=http://authentik-internal-dns-name:9000/application/o/mealie-mcp-server/jwks/

# (Optional) Required when AUTHENTIK_JWKS_URI is set.
# Authentik identifies requests by the Host header. When the MCP server
# contacts Authentik using an internal Docker DNS name, that name won't match
# what Authentik knows itself as. Set this to Authentik's public hostname so
# the correct Host header is sent on internal requests.
# Example: if your Authentik is at https://auth.your-domain.com, set this to
# auth.your-domain.com  (hostname only — no https://)
AUTHENTIK_HOST=auth.your-oauth-instance.com
