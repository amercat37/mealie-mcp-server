# Test environment configuration
# Copy to .env.testing and fill in your values.
# .env.testing is gitignored — never commit it.

# External Mealie address (used by Script 1 — test_fetcher.py)
# Use the same URL you'd use in a browser, not an internal Docker address
MEALIE_BASE_URL=http://your-mealie-host:9000

# Temporary API key created in Mealie under your user settings
# Delete this key after testing
MEALIE_API_KEY=your-temporary-test-api-key

# Log level — DEBUG shows every request and response body
LOG_LEVEL=DEBUG

# MCP server URL (used by Script 2 — test_mcp_server.py)
# The MCP server must be running in Docker before running Script 2
MCP_SERVER_URL=http://localhost:8000/mcp
