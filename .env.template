# Mealie API Configuration
# Replace these values with your own Mealie instance details

# The base URL of your Mealie instance (including protocol and port if needed)
MEALIE_BASE_URL=https://your-mealie-instance.com

# Your Mealie API key
# Generate this from your Mealie account settings
MEALIE_API_KEY=your-mealie-api-key

LOG_LEVEL=INFO

# OAuth / Authentik Configuration (optional — omit to run without auth)
# AUTHENTIK_ISSUER is the full OIDC issuer URL for your Authentik provider.
# Format: https://<your-authentik-host>/application/o/<provider-slug>/
AUTHENTIK_ISSUER=https://auth.example.com/application/o/mealie-mcp-server/

# The public base URL of this MCP server (no trailing slash, no /mcp path).
# Used as the OAuth resource identifier in protected resource metadata.
MCP_SERVER_URL=https://mealie-mcp-server.example.com

# Optional: restrict accepted tokens to a specific audience claim.
# Leave unset unless your Authentik provider explicitly sets an audience on tokens.
# AUTHENTIK_AUDIENCE=

# Optional: override the JWKS URI to fetch signing keys from an internal address
# (e.g. Docker network) instead of going through the public URL. Skips OIDC
# discovery. Leave unset to use OIDC discovery via AUTHENTIK_ISSUER.
# AUTHENTIK_JWKS_URI=http://authentik-internal-host:9000/application/o/<provider-slug>/jwks/
